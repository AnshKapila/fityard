{
  "version": 2,
  "builds": [
    {
      // Vercel requires the build `src` file to be either package.json or
      // a build.sh script. Using package.json ensures the default
      // `npm run build` command is executed, which in our case invokes
      // Vite and respects the output directory specified in vite.config.js.
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/client" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}